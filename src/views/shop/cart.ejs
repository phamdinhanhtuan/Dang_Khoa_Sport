<%- include('../partials/header') %>

    <div class="container py-5">
        <h2><i class="fas fa-shopping-cart"></i> Giỏ hàng của bạn</h2>

        <% if(cart.items.length===0) { %>
            <div class="alert alert-info mt-4">Giỏ hàng đang trống. <a href="/products">Mua sắm ngay!</a></div>
            <% } else { %>
                <div class="row mt-4">
                    <div class="col-md-8">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-0">
                                <table class="table align-middle mb-0">
                                    <thead class="bg-light">
                                        <tr>
                                            <th class="ps-4">Sản phẩm</th>
                                            <th>Giá</th>
                                            <th>Số lượng</th>
                                            <th>Thành tiền</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% cart.items.forEach(item=> { %>
                                            <tr>
                                                <td class="ps-4">
                                                    <div class="d-flex align-items-center">
                                                        <img src="<%= item.product.image %>" width="50"
                                                            class="me-3 rounded">
                                                        <div class="d-flex flex-column">
                                                            <strong>
                                                                <%= item.product.name %>
                                                            </strong>
                                                            <% if(item.size || item.color) { %>
                                                                <small class="text-muted">
                                                                    <%= item.color !=='Default' ? item.color : '' %>
                                                                        <%= (item.color !=='Default' && item.size
                                                                            !=='Default' ) ? ' | ' : '' %>
                                                                            <%= item.size !=='Default' ? item.size : ''
                                                                                %>
                                                                </small>
                                                                <% } %>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <%= (item.price || 0).toLocaleString('vi-VN') %>đ
                                                </td>
                                                <td>
                                                    <form action="/cart/update" method="POST"
                                                        class="d-flex align-items-center">
                                                        <input type="hidden" name="itemId" value="<%= item._id %>">
                                                        <div class="input-group input-group-sm" style="width: 120px;">
                                                            <input type="number" name="quantity"
                                                                class="form-control text-center"
                                                                value="<%= item.quantity %>" min="1">
                                                            <button class="btn btn-outline-secondary" type="submit"
                                                                title="Cập nhật">
                                                                <i class="fas fa-pen"></i>
                                                            </button>
                                                        </div>
                                                    </form>
                                                </td>
                                                <td class="fw-bold">
                                                    <%= ((item.price || 0) * item.quantity).toLocaleString('vi-VN') %>đ
                                                </td>
                                                <td class="text-end pe-3">
                                                    <form action="/cart/remove" method="POST">
                                                        <input type="hidden" name="itemId" value="<%= item._id %>">
                                                        <button class="btn btn-sm text-danger"><i
                                                                class="fas fa-trash"></i></button>
                                                    </form>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-white py-3">
                                <h5 class="mb-0">Tổng cộng</h5>
                            </div>
                            <div class="card-body">
                                <!-- Coupon Input -->
                                <form action="/cart/apply-coupon" method="POST" class="mb-3">
                                    <label class="form-label">Mã giảm giá</label>
                                    <div class="input-group">
                                        <input type="text" name="code" class="form-control"
                                            placeholder="Nhập mã (VD: SAVE10)"
                                            value="<%= (cart.coupon && cart.coupon.code) ? cart.coupon.code : '' %>">
                                        <button class="btn btn-outline-secondary" type="submit">Áp dụng</button>
                                    </div>
                                    <% if(cart.coupon && cart.coupon.code) { %>
                                        <div class="form-text text-success">
                                            <i class="fas fa-check-circle"></i> Đang áp dụng mã <%= cart.coupon.code %>
                                                (-<%= cart.coupon.discount %>%)
                                        </div>
                                        <% } %>
                                </form>
                                <hr>

                                <div class="d-flex justify-content-between mb-2">
                                    <span>Tạm tính:</span>
                                    <strong>
                                        <%= (cart.subTotal || cart.totalCost).toLocaleString('vi-VN') %>đ
                                    </strong>
                                </div>
                                <% if(cart.discountAmount> 0) { %>
                                    <div class="d-flex justify-content-between mb-2 text-success">
                                        <span>Giảm giá:</span>
                                        <strong>-<%= cart.discountAmount.toLocaleString('vi-VN') %>đ</strong>
                                    </div>
                                    <% } %>
                                        <div class="d-flex justify-content-between mb-3 border-top pt-2">
                                            <span class="fs-5 fw-bold">Tổng cộng:</span>
                                            <span class="fs-5 fw-bold text-danger">
                                                <%= cart.totalCost.toLocaleString('vi-VN') %>đ
                                            </span>
                                        </div>

                                        <div class="d-grid">
                                            <a href="/checkout" class="btn btn-primary btn-lg">Tiến hành thanh toán</a>
                                        </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- AI Recommendations: Cross-sell -->
                <% if(typeof recommendations !=='undefined' && recommendations && recommendations.length> 0) { %>
                    <div class="row mt-5">
                        <div class="col-12">
                            <h4 class="mb-3"><i class="fas fa-magic text-warning me-2"></i>Có thể bạn cũng thích</h4>
                        </div>
                        <% recommendations.forEach(p=> { %>
                            <div class="col-md-3 mb-4">
                                <div class="card h-100 border-0 shadow-sm">
                                    <img src="<%= p.image %>" class="card-img-top"
                                        style="height: 150px; object-fit: cover;">
                                    <div class="card-body p-3">
                                        <h6 class="card-title text-truncate">
                                            <%= p.name %>
                                        </h6>
                                        <p class="text-danger fw-bold mb-2">
                                            <%= p.price.toLocaleString('vi-VN') %>₫
                                        </p>
                                        <a href="/products/<%= p._id %>"
                                            class="btn btn-outline-primary btn-sm w-100">Xem ngay</a>
                                    </div>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } %>
                        <% } %>
    </div>

    <%- include('../partials/footer') %>
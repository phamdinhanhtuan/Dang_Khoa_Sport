<%- include('../partials/header') %>

    <div class="container mb-5" style="margin-top: 50px;">
        <div class="auth-container border border-2 border-dark rounded-0 p-5">
            <h2 class="text-center mb-4 text-uppercase fw-bold">Tạo Tài Khoản</h2>

            <% if (locals.error) { %>
                <div class="alert alert-danger rounded-0 border-danger mb-4" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    <%= error %>
                </div>
                <% } %>

                    <form action="/signup" method="POST">
                        <div class="form-group mb-3">
                            <label for="name" class="form-label fw-bold">Họ và Tên</label>
                            <input type="text" class="form-control rounded-0 p-3" id="name" name="name"
                                placeholder="Ví dụ: Nguyễn Văn A" required>
                        </div>

                        <div class="form-group mb-3">
                            <label for="email" class="form-label fw-bold">Email</label>
                            <input type="email" class="form-control rounded-0 p-3" id="email" name="email"
                                placeholder="Nhập email của bạn" required>
                        </div>

                        <div class="form-group mb-3">
                            <label for="phone" class="form-label fw-bold">Số điện thoại</label>
                            <input type="tel" class="form-control rounded-0 p-3" id="phone" name="phone"
                                placeholder="Nhập số điện thoại" required>
                        </div>

                        <div class="form-group mb-4">
                            <label for="password" class="form-label fw-bold">Mật khẩu</label>
                            <input type="password" class="form-control rounded-0 p-3" id="password" name="password"
                                placeholder="Tạo mật khẩu" required>
                        </div>

                        <button type="submit"
                            class="btn btn-primary w-100 py-3 text-uppercase rounded-0 fw-bold fs-5">ĐĂNG KÝ
                            NGAY</button>
                    </form>

                    <div class="text-center mt-4">
                        <p>Đã có tài khoản? <a href="/auth/login" class="text-danger fw-bold text-decoration-none">Đăng
                                nhập</a>
                        </p>
                    </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
<%- include('../partials/header') %>

    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Chi tiết đơn hàng #<%= order._id.toString().slice(-6).toUpperCase() %>
            </h2>
            <a href="/orders" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i> Quay lại</a>
        </div>

        <div class="row">
            <!-- Order Info -->
            <div class="col-md-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0">Sản phẩm</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead class="bg-light">
                                    <tr>
                                        <th class="ps-4">Sản phẩm</th>
                                        <th>Đơn giá</th>
                                        <th>Số lượng</th>
                                        <th>Thành tiền</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% order.items.forEach(item=> { %>
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                    <% if(item.product.image) { %>
                                                        <img src="<%= item.product.image %>" width="60"
                                                            class="me-3 rounded border">
                                                        <% } else { %>
                                                            <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded me-3"
                                                                style="width: 60px; height: 60px;">No Img</div>
                                                            <% } %>
                                                                <div>
                                                                    <div class="fw-bold">
                                                                        <%= item.product.name || 'Sản phẩm đã bị xóa' %>
                                                                    </div>
                                                                    <% if(item.color || item.size) { %>
                                                                        <small class="text-muted d-block">
                                                                            <%= item.color && item.color !=='Default'
                                                                                ? 'Màu: ' + item.color : '' %>
                                                                                <%= (item.color && item.color
                                                                                    !=='Default' && item.size &&
                                                                                    item.size !=='Default' ) ? '|' : ''
                                                                                    %>
                                                                                    <%= item.size && item.size
                                                                                        !=='Default' ? 'Size: ' +
                                                                                        item.size : '' %>
                                                                        </small>
                                                                        <% } %>
                                                                </div>
                                                </div>
                                            </td>
                                            <td>
                                                <%= item.price.toLocaleString('vi-VN') %>đ
                                            </td>
                                            <td>x<%= item.quantity %>
                                            </td>
                                            <td class="fw-bold">
                                                <%= (item.price * item.quantity).toLocaleString('vi-VN') %>đ
                                            </td>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Summary & Shipping -->
            <div class="col-md-4">
                <!-- Status -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Trạng thái đơn hàng</h5>
                        <% if(order.status==='pending' ) { %>
                            <div class="alert alert-warning mb-0"><i class="fas fa-clock me-2"></i> Chờ xử lý</div>
                            <% } else if(order.status==='completed' ) { %>
                                <div class="alert alert-success mb-0"><i class="fas fa-check-circle me-2"></i> Hoàn
                                    thành</div>
                                <% } else { %>
                                    <div class="alert alert-info mb-0 text-capitalize">
                                        <%= order.status %>
                                    </div>
                                    <% } %>
                                        <div class="mt-2 text-muted small">
                                            Ngày đặt: <%= new Date(order.createdAt).toLocaleString('vi-VN') %>
                                        </div>
                    </div>
                </div>

                <!-- Shipping Address -->
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0">Thông tin giao hàng</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><strong>
                                <%= order.shippingAddress.fullName %>
                            </strong></p>
                        <p class="mb-1"><a href="tel:<%= order.shippingAddress.phone %>" class="text-decoration-none">
                                <%= order.shippingAddress.phone %>
                            </a></p>
                        <p class="mb-1">
                            <%= order.shippingAddress.addressLine %>
                        </p>
                        <p class="mb-0">
                            <%= order.shippingAddress.district %> - <%= order.shippingAddress.city %>
                        </p>
                        <% if(order.shippingAddress.note) { %>
                            <hr class="my-2">
                            <small class="text-muted d-block">Ghi chú:</small>
                            <p class="mb-0 fst-italic">
                                <%= order.shippingAddress.note %>
                            </p>
                            <% } %>
                    </div>
                </div>

                <!-- Total -->
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-5">Tổng cộng:</span>
                            <strong class="fs-4 text-danger">
                                <%= order.totalAmount.toLocaleString('vi-VN') %>đ
                            </strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('../partials/footer') %>
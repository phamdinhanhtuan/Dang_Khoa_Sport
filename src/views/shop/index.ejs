                    }
                </style>

                <!-- Add Cart Script (Re-use existing ajax or ensure global script handles it) -->
                <script>
                    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
                        btn.addEventListener('click', async (e) => {
                            const productId = btn.dataset.id;
                            try {
                                const res = await fetch('/cart/add', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ productId, quantity: 1 })
                                });
                                const data = await res.json();
                                if (res.ok) {
                                    // Update cart badge (assuming id 'cart-count' exists in header)
                                    const badge = document.getElementById('cart-count');
                                    if (badge) badge.innerText = data.totalQty;

                                    // Optional: Show toast/alert
                                    // alert('Đã thêm vào giỏ hàng'); 
                                } else {
                                    alert(data.message || 'Lỗi thêm vào giỏ');
                                }
                            } catch (err) {
                                console.error(err);
                                alert('Có lỗi xảy ra');
                            }
                        });
                    });
                </script>
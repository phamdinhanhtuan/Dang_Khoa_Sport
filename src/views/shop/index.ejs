                        transform: translateY(10px);
                        transition: all 0.3s;
                    }

                    .product-card:hover .product-actions {
                        opacity: 1;
                        transform: translateY(0);
                    }

                    .product-card:hover {
                        transform: translateY(-5px);
                        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .15) !important;
                    }


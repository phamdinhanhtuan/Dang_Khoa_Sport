<%- include('partials/header') %>

    <div class="row min-vh-75 align-items-center justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg border-start border-5 border-danger p-5">
                <div class="d-flex align-items-center mb-4">
                    <i class="fas fa-exclamation-triangle text-danger fa-3x me-4"></i>
                    <div>
                        <h1 class="h2 text-dark fw-bold mb-0">System Error</h1>
                        <p class="text-muted mb-0">An unexpected error occurred in the Admin Portal.</p>
                    </div>
                </div>

                <div class="alert alert-light border mb-4">
                    <h6 class="fw-bold"><i class="fas fa-info-circle me-2"></i>Error Message:</h6>
                    <p class="mb-0 text-danger font-monospace">
                        <%= message %>
                    </p>
                </div>

                <% if (process.env.NODE_ENV==='development' && typeof error !=='undefined' && error.stack) { %>
                    <div class="mt-3">
                        <button class="btn btn-sm btn-link text-muted p-0 text-decoration-none mb-2" type="button"
                            data-bs-toggle="collapse" data-bs-target="#stackTrace">
                            <i class="fas fa-bug me-1"></i>View Technical Stack Trace
                        </button>
                        <div class="collapse" id="stackTrace">
                            <div class="bg-dark text-light p-3 rounded small overflow-auto" style="max-height: 250px;">
                                <pre class="mb-0"><code><%= error.stack %></code></pre>
                            </div>
                        </div>
                    </div>
                    <% } %>

                        <hr class="my-4">

                        <div class="d-flex gap-2">
                            <a href="/admin" class="btn btn-primary px-4">Return to Dashboard</a>
                            <button onclick="location.reload()" class="btn btn-outline-dark px-4">Retry Request</button>
                        </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
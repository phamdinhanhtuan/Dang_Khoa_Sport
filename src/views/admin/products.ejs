<%- include('partials/header') %>

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h3 class="fw-bold mb-0">Product Management</h3>
            <p class="text-muted small mb-0">Manage inventory and catalog</p>
        </div>
        <div class="d-flex gap-2">
            <form action="/admin/products" method="GET" class="d-flex gap-2">
                <select name="category" class="form-select" onchange="this.form.submit()">
                    <option value="">All Categories</option>
                    <% categories.forEach(cat=> { %>
                        <option value="<%= cat._id %>" <%=currentCategory==cat._id ? 'selected' : '' %>><%= cat.name %>
                        </option>
                        <% }) %>
                </select>
                <input type="text" name="q" class="form-control" placeholder="Search products..."
                    value="<%= searchQuery %>">
                <!-- Submit button implicit or explicit if needed, but select triggers submit -->
                <button type="submit" class="btn btn-outline-secondary"><i class="fas fa-search"></i></button>
            </form>
            <a href="/admin/products/new" class="btn btn-primary text-nowrap"><i class="fas fa-plus me-1"></i> Add
                Product</a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Image</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (products.length> 0) { %>
                            <% products.forEach(product=> { %>
                                <tr>
                                    <td class="ps-4">
                                        <img src="<%= product.image && product.image.startsWith('http') ? product.image : (product.image ? product.image : 'https://via.placeholder.com/50') %>"
                                            alt="<%= product.name %>" class="rounded border"
                                            style="width: 40px; height: 40px; object-fit: cover;">
                                    </td>
                                    <td>
                                        <div class="fw-bold">
                                            <%= product.name %>
                                        </div>
                                        <% if(product.brand) { %><small class="text-muted">
                                                <%= product.brand %>
                                            </small>
                                            <% } %>
                                    </td>
                                    <td><span class="badge bg-light text-dark border">
                                            <%= product.category ? product.category.name : 'Uncategorized' %>
                                        </span></td>
                                    <td class="fw-bold text-success">
                                        <%= new Intl.NumberFormat('vi-VN', { style: 'currency' , currency: 'VND'
                                            }).format(product.price) %>
                                    </td>
                                    <td>
                                        <span
                                            class="badge rounded-pill bg-<%= product.stock > 10 ? 'success' : (product.stock > 0 ? 'warning' : 'danger') %> bg-opacity-75">
                                            <%= product.stock %>
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="/admin/products/<%= product._id %>/edit"
                                            class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>

                                        <a href="/admin/products/<%= product._id %>/delete"
                                            class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Are you sure you want to delete this product?');"><i
                                                class="fas fa-trash"></i></a>
                                    </td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6" class="text-center py-5 text-muted">
                                                <i class="fas fa-box-open fa-3x mb-3 opacity-25"></i><br>
                                                No products found matching your criteria.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
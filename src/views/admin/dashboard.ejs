<%- include('partials/header') %>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card h-100 p-4 border-0 shadow-sm"
                style="background: linear-gradient(135deg, #4318ff 0%, #707eff 100%); color: white;">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="opacity-75 small fw-bold text-uppercase">Total Revenue</h6>
                        <h3 class="fw-bold mb-0 mt-2">
                            <%= formatMoney(totalRevenue) %>
                        </h3>
                    </div>
                    <div class="bg-white bg-opacity-25 rounded-circle p-3 d-flex align-items-center justify-content-center"
                        style="width: 50px; height: 50px;">
                        <i class="fas fa-wallet fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 p-4 border-0 shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase">Total Orders</h6>
                        <h3 class="text-dark fw-bold mb-0 mt-2">
                            <%= orderCount %>
                        </h3>
                    </div>
                    <div class="bg-light rounded-circle p-3 d-flex align-items-center justify-content-center"
                        style="width: 50px; height: 50px; color: #4318ff;">
                        <i class="fas fa-shopping-cart fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 p-4 border-0 shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase">Products</h6>
                        <h3 class="text-dark fw-bold mb-0 mt-2">
                            <%= productCount %>
                        </h3>
                    </div>
                    <div class="bg-light rounded-circle p-3 d-flex align-items-center justify-content-center"
                        style="width: 50px; height: 50px; color: #05cd99;">
                        <i class="fas fa-box fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 p-4 border-0 shadow-sm">
                <div class="d-flex justify-content-between">
                    <div>
                        <h6 class="text-muted small fw-bold text-uppercase">Customers</h6>
                        <h3 class="text-dark fw-bold mb-0 mt-2">
                            <%= userCount %>
                        </h3>
                    </div>
                    <div class="bg-light rounded-circle p-3 d-flex align-items-center justify-content-center"
                        style="width: 50px; height: 50px; color: #ffbc11;">
                        <i class="fas fa-users fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Revenue Chart (Simplified Visualization) -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-4">Monthly Revenue Statistics</h5>
                <div class="d-flex align-items-end gap-3" style="height: 300px;">
                    <% const months=['Jan', 'Feb' , 'Mar' , 'Apr' , 'May' , 'Jun' , 'Jul' , 'Aug' , 'Sep' , 'Oct'
                        , 'Nov' , 'Dec' ]; const maxRev=Math.max(...monthlyRevenue.map(m=> m.revenue), 1000000);
                        %>
                        <% monthlyRevenue.forEach(function(stat) { %>
                            <div class="flex-grow-1 text-center">
                                <% let chartHeightString=((stat.revenue / maxRev) * 100) + '%' ; %>
                                    <div class="bg-primary rounded-top"
                                        style="height: <%= chartHeightString %>; min-height: 5px; opacity: 0.8;"
                                        title="<%= formatMoney(stat.revenue) %>">
                                    </div>
                                    <p class="mt-2 mb-0 small text-muted">
                                        <%= months[stat._id - 1] %>
                                    </p>
                            </div>
                            <% }) %>
                </div>
            </div>
        </div>

        <!-- Inventory Alert -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h5 class="fw-bold mb-4 text-danger"><i class="fas fa-exclamation-triangle me-2"></i>Low Stock Alert
                </h5>
                <% if (lowStockProducts.length> 0) { %>
                    <div class="list-group list-group-flush">
                        <% lowStockProducts.forEach(product=> { %>
                            <div class="list-group-item px-0 py-3 bg-transparent border-bottom">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <p class="mb-0 fw-bold small">
                                            <%= product.name %>
                                        </p>
                                        <small class="text-muted">ID: <%= product._id.toString().substring(18) %>
                                        </small>
                                    </div>
                                    <span class="badge badge-soft-danger">
                                        <%= product.stock %> items left
                                    </span>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <a href="/admin/products" class="btn btn-sm btn-outline-primary mt-4">Manage Inventory</a>
                    <% } else { %>
                        <div class="text-center py-5">
                            <i class="fas fa-check-circle text-success fa-3x mb-3"></i>
                            <p class="text-muted">All products are well stocked.</p>
                        </div>
                        <% } %>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
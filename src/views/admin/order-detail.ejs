<%- include('partials/header') %>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>Order Details <small class="text-muted">#<%= order._id.toString().slice(-6) %></small></h3>
        <a href="/admin/orders" class="btn btn-outline-secondary"><i class="fas fa-arrow-left"></i> Back to Orders</a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <!-- Products -->
            <div class="card mb-4">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Items</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-end">Price</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% order.items.forEach(item=> { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <% if (item.product && item.product.image) { %>
                                                <img src="<%= item.product.image.startsWith('http') ? item.product.image : '/images/products/' + item.product.image %>"
                                                    style="width: 40px; height: 40px; object-fit: cover; margin-right: 10px;"
                                                    class="rounded">
                                                <% } %>
                                                    <%= item.product ? item.product.name : 'Unknown Product' %>
                                        </div>
                                    </td>
                                    <td class="text-end">
                                        <%= new Intl.NumberFormat('vi-VN', { style: 'currency' , currency: 'VND'
                                            }).format(item.price) %>
                                    </td>
                                    <td class="text-center">
                                        <%= item.quantity %>
                                    </td>
                                    <td class="text-end">
                                        <%= new Intl.NumberFormat('vi-VN', { style: 'currency' , currency: 'VND'
                                            }).format(item.price * item.quantity) %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Grand Total:</td>
                                <td class="text-end fw-bold text-primary">
                                    <%= new Intl.NumberFormat('vi-VN', { style: 'currency' , currency: 'VND'
                                        }).format(order.totalAmount) %>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- Shipping -->
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Shipping Information</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small text-uppercase">Full Name</label>
                            <p class="fw-bold">
                                <%= order.shippingAddress.fullName %>
                            </p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="text-muted small text-uppercase">Phone</label>
                            <p class="fw-bold">
                                <%= order.shippingAddress.phone %>
                            </p>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="text-muted small text-uppercase">Address</label>
                            <p class="fw-bold">
                                <%= order.shippingAddress.addressLine %>,
                                    <%= order.shippingAddress.city %>,
                                        <%= order.shippingAddress.province %>
                            </p>
                        </div>
                        <% if (order.shippingAddress.note) { %>
                            <div class="col-12">
                                <label class="text-muted small text-uppercase">Note</label>
                                <p class="fst-italic">
                                    <%= order.shippingAddress.note %>
                                </p>
                            </div>
                            <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <!-- Status -->
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">Order Status</h5>

                    <form action="/admin/orders/<%= order._id %>" method="POST">
                        <div class="mb-3">
                            <select name="status" class="form-select form-select-lg mb-3">
                                <option value="pending" <%=order.status==='pending' ? 'selected' : '' %>>Pending
                                </option>
                                <option value="paid" <%=order.status==='paid' ? 'selected' : '' %>>Paid</option>
                                <option value="shipped" <%=order.status==='shipped' ? 'selected' : '' %>>Shipped
                                </option>
                                <option value="completed" <%=order.status==='completed' ? 'selected' : '' %>>Completed
                                </option>
                                <option value="cancelled" <%=order.status==='cancelled' ? 'selected' : '' %>>Cancelled
                                </option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Update Status</button>
                    </form>
                </div>
            </div>

            <!-- User -->
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title mb-3">Customer</h5>
                    <div class="d-flex align-items-center">
                        <div class="bg-light rounded-circle p-3 me-3">
                            <i class="fas fa-user fa-lg text-secondary"></i>
                        </div>
                        <div>
                            <h6 class="mb-0">
                                <%= order.user ? order.user.name : 'Guest' %>
                            </h6>
                            <small class="text-muted">
                                <%= order.user ? order.user.email : 'No email' %>
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
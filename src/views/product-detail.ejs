<%- include('partials/header') %>
    <div class="container py-5">
        <div class="row">
            <div class="col-lg-6">
                <!-- Main Image -->
                <!-- Main Image -->
                <!-- Main Image -->
                <div class="card border-0 mb-3 d-flex align-items-center justify-content-center bg-white position-relative overflow-hidden"
                    style="height: 500px; max-height: 60vh; cursor: zoom-in;" data-bs-toggle="modal"
                    data-bs-target="#lightboxModal">
                    <img id="mainProductImage"
                        src="<%= (product.images && product.images.length > 0) ? product.images[0] : (product.image || '/img/default-product.png') %>"
                        class="img-fluid" style="max-height: 100%; max-width: 100%; object-fit: contain;"
                        alt="<%= product.name %>" onerror="this.src='/img/default-product.png'">
                </div>

                <!-- Thumbnails -->
                <div class="d-flex gap-2 overflow-auto pb-2">
                    <% if(product.images && product.images.length> 0) { %>
                        <% product.images.forEach((img, index)=> { %>
                            <div class="border rounded p-1 thumbnail-wrapper <%= index === 0 ? 'border-dark' : 'border-light' %>"
                                style="cursor: pointer; transition: all 0.2s;"
                                onclick="changeMainImage(this, '<%= img %>')">
                                <img src="<%= img %>" class="img-fluid"
                                    style="width: 80px; height: 80px; object-fit: contain;">
                            </div>
                            <% }) %>
                                <% } %>
                </div>
            </div>
            <div class="col-lg-6">
                <h2 class="fw-bold mb-2 display-6" style="font-weight: 800;">
                    <%= product.name %>
                </h2>

                <div class="mb-3">
                    <div class="d-flex align-items-baseline">
                        <span class="h3 fw-bold mb-0">
                            <%= formatMoney(product.price) %>
                        </span>
                    </div>
                    <small class="text-secondary" style="font-size: 0.9rem;">Đã bao gồm 8% thuế VAT</small>
                </div>

                <!-- Colors -->
                <div class="mb-4">
                    <h6 class="fw-bold mb-2">Màu <span id="selectedColorDisplay" class="text-muted fw-normal"></span>
                    </h6>
                    <div class="d-flex gap-2" id="colorOptions">
                        <div class="color-option p-1 border border-2 border-dark rounded-circle d-flex align-items-center justify-content-center"
                            style="cursor: pointer; width: 40px; height: 40px;" data-value="Black"
                            onclick="selectColor(this)">
                            <span class="rounded-circle w-100 h-100"
                                style="background-color: #000; display: block;"></span>
                        </div>
                        <div class="color-option p-1 border border-light rounded-circle d-flex align-items-center justify-content-center"
                            style="cursor: pointer; width: 40px; height: 40px; opacity: 0.7;" data-value="White"
                            onclick="selectColor(this)">
                            <span class="rounded-circle w-100 h-100 border"
                                style="background-color: #fff; display: block;"></span>
                        </div>
                        <div class="color-option p-1 border border-light rounded-circle d-flex align-items-center justify-content-center"
                            style="cursor: pointer; width: 40px; height: 40px; opacity: 0.7;" data-value="Orange"
                            onclick="selectColor(this)">
                            <span class="rounded-circle w-100 h-100"
                                style="background-color: #f0ad4e; display: block;"></span>
                        </div>
                    </div>
                </div>

                <!-- Sizes -->
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-bold mb-0">Kích cỡ <span id="selectedSizeDisplay"
                                class="text-muted fw-normal"></span></h6>
                        <a href="#" class="text-decoration-none text-dark small fw-bold" data-bs-toggle="modal"
                            data-bs-target="#sizeGuideModal">
                            BẢNG HƯỚNG DẪN VỀ KÍCH CỠ <i class="fas fa-ruler ms-1"></i>
                        </a>
                    </div>
                    <div class="d-flex flex-wrap gap-2" id="sizeOptions">
                        <% let isShoe=false; /* Check Category */ if (product.category && product.category.name) { const
                            catName=product.category.name.toLowerCase(); const catSlug=product.category.slug ?
                            product.category.slug.toLowerCase() : '' ; if (catName.includes('giày') ||
                            catName.includes('dép') || catSlug.includes('footwear') || catSlug.includes('shoes')) {
                            isShoe=true; } } /* Fallback Check Name */ if (!isShoe && product.name) { const
                            name=product.name.toLowerCase(); if (name.includes('giày') || name.includes('dép') ||
                            name.includes('shoes') || name.includes('sandal') || name.includes('sneaker') ||
                            name.includes('slide')) { isShoe=true; } } const shoeSizes=['EUR 39', 'EUR 40' , 'EUR 40.5'
                            , 'EUR 41' , 'EUR 42' , 'EUR 43' , 'EUR 44.5' , 'EUR 46' ]; const clothingSizes=['XS', 'S'
                            , 'M' , 'L' , 'XL' , 'XXL' ]; const sizesToShow=isShoe ? shoeSizes : clothingSizes; %>
                            <% sizesToShow.forEach(function(size) { %>
                                <button type="button" class="btn btn-outline-dark rounded-0 px-3 py-2 size-option"
                                    onclick="selectSize(this)">
                                    <%= size %>
                                </button>
                                <% }); %>
                    </div>
                </div>

                <!-- Share -->
                <div class="mb-4 text-end">
                    <span class="me-2 text-muted">Chia sẻ trên mạng xã hội</span>
                    <a href="#" class="text-dark me-2"><i class="fab fa-facebook fa-lg"></i></a>
                    <a href="#" class="text-dark"><i class="fab fa-pinterest fa-lg"></i></a>
                </div>

                <!-- Add to Cart Form -->
                <form id="addToCartForm" class="mt-auto">
                    <input type="hidden" name="productId" value="<%= product._id %>">
                    <input type="hidden" name="color" id="inputColor" value="Black">
                    <input type="hidden" name="size" id="inputSize" value="">

                    <div class="d-flex gap-2">
                        <div class="form-floating" style="width: 100px;">
                            <select class="form-select rounded-0" id="quantitySelect" name="quantity"
                                aria-label="Quantity">
                                <% for(let i=1; i<=10; i++) { %>
                                    <option value="<%= i %>">
                                        <%= i %>
                                    </option>
                                    <% } %>
                            </select>
                            <label for="quantitySelect">SỐ LƯỢNG</label>
                        </div>

                        <% if (product.stock> 0 && product.stock <= 5) { %>
                                <div class="alert alert-warning py-2 mb-0 d-flex align-items-center small" role="alert">
                                    <i class="fas fa-exclamation-triangle me-2"></i> Only <%= product.stock %> items
                                        left!
                                </div>
                                <% } %>

                                    <button type="submit"
                                        class="btn btn-dark btn-lg flex-grow-1 rounded-0 fw-bold text-white shadow-none"
                                        style="font-size: 1.1rem; padding: 12px;" <%=product.stock===0 ? 'disabled' : ''
                                        %>>
                                        <%= product.stock===0 ? 'HẾT HÀNG' : 'THÊM VÀO GIỎ' %>
                                    </button>

                                    <button type="button" class="btn btn-lg border rounded-0 px-3" id="addToWishlistBtn"
                                        data-id="<%= product._id %>">
                                        <i
                                            class="<%= (user && user.wishlist && user.wishlist.includes(product._id.toString())) ? 'fas' : 'far' %> fa-heart text-danger"></i>
                                    </button>
                    </div>
                </form>

                <script>
                    function selectColor(el) {
                        // Remove active class from all
                        document.querySelectorAll('.color-option').forEach(opt => {
                            opt.classList.remove('border-dark');
                            opt.classList.add('border-light');
                            opt.style.opacity = '0.6';
                        });
                        // Add active class to clicked
                        el.classList.remove('border-light');
                        el.classList.add('border-dark');
                        el.style.opacity = '1';

                        // Update input
                        const val = el.getAttribute('data-value');
                        document.getElementById('inputColor').value = val;
                        document.getElementById('selectedColorDisplay').innerText = ': ' + val;
                    }

                    function selectSize(btn) {
                        // Remove active class
                        document.querySelectorAll('.size-option').forEach(opt => {
                            opt.classList.remove('btn-dark');
                            opt.classList.add('btn-outline-dark');
                        });
                        // Add active class
                        btn.classList.remove('btn-outline-dark');
                        btn.classList.add('btn-dark');

                        // Update input
                        const val = btn.innerText;
                        document.getElementById('inputSize').value = val;
                        document.getElementById('selectedSizeDisplay').innerText = ': ' + val;
                    }

                    // Select first color by default
                    document.addEventListener('DOMContentLoaded', () => {
                        const firstColor = document.querySelector('.color-option');
                        if (firstColor) selectColor(firstColor);
                    });
                </script>

                <hr>

                <!-- Product Story & Details -->
                <div class="row mt-5">
                    <div class="col-12 mb-5">
                        <h4 class="fw-bold mb-3">PRODUCT STORY</h4>
                        <p class="text-muted" style="line-height: 1.8;">
                            <%= product.description
                                || "Slide into these Sandals for instant motorsport vibes. The padded strap feels soft against your foot, and the moulded footbed cushions every step. Whether poolside or street-bound, you get grip, ease, and a look that's all about cool confidence."
                                %>
                        </p>
                    </div>

                    <div class="col-md-6 mb-4">
                        <h5 class="fw-bold mb-4">DETAILS</h5>
                        <ul class="list-unstyled text-muted">
                            <li class="mb-2 d-flex"><span style="width: 150px;">Width:</span> Regular</li>
                            <li class="mb-2 d-flex"><span style="width: 150px;">Toe type:</span> Rounded</li>
                            <li class="mb-2 d-flex"><span style="width: 150px;">Closure:</span> Slip on</li>
                            <li class="mb-2 d-flex"><span style="width: 150px;">Heel type:</span> Flat</li>
                        </ul>
                    </div>

                    <div class="col-md-6 mb-4">
                        <h5 class="fw-bold mb-4">ĐỊA CHỈ NHÀ SẢN XUẤT</h5>
                        <p class="text-muted">
                            Fuqing Baiyi Shoes Industry<br>
                            Co.,Ltd<br>
                            FCNFU<br>
                            No.167 Qishipu, Shapu town<br>
                            350322
                        </p>
                    </div>
                </div>

                <hr class="my-5">

                <!-- Reviews Section -->
                <div class="row">
                    <div class="col-12">
                        <h4 class="fw-bold mb-4">ĐÁNH GIÁ SẢN PHẨM (<%= product.reviews ? product.reviews.length : 0 %>)
                        </h4>

                        <div class="row">
                            <div class="col-md-4 mb-4">
                                <div
                                    class="bg-light p-4 text-center h-100 d-flex flex-column justify-content-center align-items-center">
                                    <h1 class="display-3 fw-bold mb-0">
                                        <%= product.ratingsAverage || '0' %>
                                    </h1>
                                    <div class="text-warning mb-2">
                                        <% for(let i=1; i<=5; i++) { %>
                                            <i
                                                class="<%= (product.ratingsAverage >= i) ? 'fas' : ((product.ratingsAverage >= i-0.5) ? 'fas fa-star-half-alt' : 'far') %> fa-star"></i>
                                            <% } %>
                                    </div>
                                    <p class="text-muted">
                                        <%= product.ratingsQuantity || 0 %> đánh giá
                                    </p>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <!-- Review Form -->
                                <% if (user) { %>
                                    <div class="mb-5">
                                        <h6 class="fw-bold mb-3">Viết đánh giá của bạn</h6>
                                        <form id="reviewForm">
                                            <input type="hidden" name="product" value="<%= product._id %>">
                                            <div class="mb-3">
                                                <label class="form-label small">Đánh giá của bạn:</label>
                                                <div class="rating-input">
                                                    <div class="btn-group" role="group">
                                                        <% for(let i=1; i<=5; i++) { %>
                                                            <input type="radio" class="btn-check" name="rating"
                                                                id="rating<%= i %>" value="<%= i %>" required>
                                                            <label class="btn btn-outline-warning" for="rating<%= i %>">
                                                                <%= i %> <i class="fas fa-star"></i>
                                                            </label>
                                                            <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label small">Nội dung:</label>
                                                <textarea class="form-control rounded-0" name="review" rows="3" required
                                                    placeholder="Chia sẻ cảm nhận của bạn về sản phẩm..."></textarea>
                                            </div>
                                            <button type="submit" class="btn btn-dark rounded-0 px-4">GỬI ĐÁNH
                                                GIÁ</button>
                                        </form>
                                    </div>
                                    <% } else { %>
                                        <div class="alert alert-secondary mb-4">
                                            Vui lòng <a href="/login" class="alert-link">đăng nhập</a> để viết đánh giá.
                                        </div>
                                        <% } %>

                                            <!-- Review List -->
                                            <div class="review-list" style="max-height: 500px; overflow-y: auto;">
                                                <% if (product.reviews && product.reviews.length> 0) { %>
                                                    <% product.reviews.forEach(review=> { %>
                                                        <div class="border-bottom pb-3 mb-3">
                                                            <div
                                                                class="d-flex justify-content-between align-items-center mb-2">
                                                                <div class="d-flex align-items-center gap-2">
                                                                    <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center"
                                                                        style="width: 30px; height: 30px;">
                                                                        <%= review.user.name.charAt(0).toUpperCase() %>
                                                                    </div>
                                                                    <span class="fw-bold">
                                                                        <%= review.user.name %>
                                                                    </span>
                                                                    <span class="badge bg-success small"><i
                                                                            class="fas fa-check-circle"></i> Đã mua
                                                                        hàng</span>
                                                                </div>
                                                                <small class="text-muted">
                                                                    <%= new
                                                                        Date(review.createdAt).toLocaleDateString('vi-VN')
                                                                        %>
                                                                </small>
                                                            </div>
                                                            <div class="text-warning small mb-2">
                                                                <% for(let i=1; i<=5; i++) { %>
                                                                    <i
                                                                        class="<%= (review.rating >= i) ? 'fas' : 'far' %> fa-star"></i>
                                                                    <% } %>
                                                            </div>
                                                            <p class="mb-0 text-muted">
                                                                <%= review.review %>
                                                            </p>
                                                        </div>
                                                        <% }) %>
                                                            <% } else { %>
                                                                <p class="text-muted text-center py-4">Chưa có đánh giá
                                                                    nào.</p>
                                                                <% } %>
                                            </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- End Main Content Col -->
            </div>
        </div>

        <hr class="my-5">

        <!-- Related Products -->
        <div class="mb-5">
            <h3 class="fw-bold mb-4 text-uppercase">Sản Phẩm Tương Tự</h3>
            <div class="row row-cols-2 row-cols-md-4 g-4">
                <% if (typeof relatedProducts !=='undefined' && relatedProducts.length> 0) { %>
                    <% relatedProducts.forEach(relProd=> { %>
                        <div class="col">
                            <div class="card h-100 border-0">
                                <div class="position-relative mb-3 overflow-hidden">
                                    <a href="/product/<%= relProd._id %>">
                                        <div class="ratio ratio-1x1 bg-light">
                                            <img src="<%= (relProd.images && relProd.images[0]) || 'https://dummyimage.com/600x600/f4f4f4/aaa' %>"
                                                class="card-img-top w-100 h-100"
                                                style="object-fit: contain; padding: 10px;" alt="<%= relProd.name %>">
                                        </div>
                                    </a>
                                    <!-- Sale Badge (Mock) -->
                                    <% if (Math.random()> 0.5) { %>
                                        <span
                                            class="position-absolute top-0 start-0 bg-danger text-white px-2 py-1 small fw-bold m-2">
                                            -30%
                                        </span>
                                        <% } %>
                                </div>
                                <div class="card-body p-0">
                                    <h6 class="card-title fw-bold mb-1 text-truncate">
                                        <a href="/product/<%= relProd._id %>" class="text-decoration-none text-dark">
                                            <%= relProd.name %>
                                        </a>
                                    </h6>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-danger fw-bold">
                                            <%= formatMoney(relProd.price) %>
                                        </span>
                                        <span class="text-muted text-decoration-line-through small">
                                            <%= formatMoney(relProd.price * 1.3) %>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                            <% } %>
            </div>
        </div>
        <!-- Lightbox Modal -->
        <div class="modal fade" id="lightboxModal" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
            <div class="modal-dialog modal-dialog-centered modal-xl modal-fullscreen-lg-down">
                <div class="modal-content bg-transparent border-0 shadow-none">
                    <div class="modal-body p-0 d-flex justify-content-center align-items-center position-relative">
                        <button type="button"
                            class="btn-close btn-close-white position-absolute top-0 end-0 m-3 p-3 text-white"
                            data-bs-dismiss="modal" aria-label="Close"
                            style="z-index: 1070; background-color: rgba(0,0,0,0.5); border-radius: 50%; opacity: 1;"></button>
                        <img id="lightboxImage" src="" class="img-fluid"
                            style="max-height: 90vh; object-fit: contain; box-shadow: 0 0 50px rgba(0,0,0,0.5);">
                    </div>
                </div>
            </div>
        </div>

        <!-- Image Interaction Script -->
        <script>
            function changeMainImage(element, src) {
                // Update Main Image
                const mainImg = document.getElementById('mainProductImage');
                mainImg.style.opacity = '0.5';
                setTimeout(() => {
                    mainImg.src = src;
                    mainImg.style.opacity = '1';
                    // Update Lightbox Source
                    updateLightboxImage(src);
                }, 150);

                // Update Active Thumbnail
                document.querySelectorAll('.thumbnail-wrapper').forEach(el => {
                    el.classList.remove('border-dark');
                    el.classList.add('border-light');
                });
                element.classList.remove('border-light');
                element.classList.add('border-dark');
            }

            // Initialize Lightbox Image on open
            const lightboxModal = document.getElementById('lightboxModal');
            if (lightboxModal) {
                lightboxModal.addEventListener('show.bs.modal', function () {
                    const currentSrc = document.getElementById('mainProductImage').src;
                    updateLightboxImage(currentSrc);
                });
            }

            function updateLightboxImage(src) {
                const lightboxImg = document.getElementById('lightboxImage');
                if (lightboxImg) lightboxImg.src = src;
            }
        </script>

        <%- include('partials/footer') %>

            <!-- Size Guide Modal -->
            <!-- Size Guide Modal -->
            <div class="modal fade" id="sizeGuideModal" tabindex="-1" aria-labelledby="sizeGuideModalLabel"
                aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-centered">
                    <div class="modal-content rounded-0">
                        <div class="modal-header border-0">
                            <h5 class="modal-title fw-bold" id="sizeGuideModalLabel">HƯỚNG Dẫn CHỌN KÍCH CỠ</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <% let isShoeModal=false; if (product.category && product.category.name) { const
                                catName=product.category.name.toLowerCase(); const catSlug=product.category.slug ?
                                product.category.slug.toLowerCase() : '' ; if (catName.includes('giày') ||
                                catName.includes('dép') || catName.includes('footwear') || catSlug.includes('footwear')
                                || catSlug.includes('shoes')) { isShoeModal=true; } } if (!isShoeModal && product.name)
                                { const name=product.name.toLowerCase(); if (name.includes('giày') ||
                                name.includes('dép') || name.includes('shoes') || name.includes('sandal') ||
                                name.includes('sneaker') || name.includes('slide')) { isShoeModal=true; } } %>

                                <% if(isShoeModal) { %>
                                    <!-- Shoe Size Table -->
                                    <h6 class="fw-bold mb-3">Bảng Kích Cỡ Giày</h6>
                                    <table class="table table-bordered text-center align-middle">
                                        <thead class="table-dark">
                                            <tr>
                                                <th>Kích thước (EUR)</th>
                                                <th>Kích thước (US Men)</th>
                                                <th>Kích thước (UK)</th>
                                                <th>Chiều dài chân (cm)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr>
                                                <td>39</td>
                                                <td>7</td>
                                                <td>6</td>
                                                <td>25</td>
                                            </tr>
                                            <tr>
                                                <td>40</td>
                                                <td>7.5</td>
                                                <td>6.5</td>
                                                <td>25.5</td>
                                            </tr>
                                            <tr>
                                                <td>40.5</td>
                                                <td>8</td>
                                                <td>7</td>
                                                <td>26</td>
                                            </tr>
                                            <tr>
                                                <td>41</td>
                                                <td>8.5</td>
                                                <td>7.5</td>
                                                <td>26.5</td>
                                            </tr>
                                            <tr>
                                                <td>42</td>
                                                <td>9</td>
                                                <td>8</td>
                                                <td>27</td>
                                            </tr>
                                            <tr>
                                                <td>42.5</td>
                                                <td>9.5</td>
                                                <td>8.5</td>
                                                <td>27.5</td>
                                            </tr>
                                            <tr>
                                                <td>43</td>
                                                <td>10</td>
                                                <td>9</td>
                                                <td>28</td>
                                            </tr>
                                            <tr>
                                                <td>44</td>
                                                <td>10.5</td>
                                                <td>9.5</td>
                                                <td>28.5</td>
                                            </tr>
                                            <tr>
                                                <td>44.5</td>
                                                <td>11</td>
                                                <td>10</td>
                                                <td>29</td>
                                            </tr>
                                            <tr>
                                                <td>45</td>
                                                <td>11.5</td>
                                                <td>10.5</td>
                                                <td>29.5</td>
                                            </tr>
                                            <tr>
                                                <td>46</td>
                                                <td>12</td>
                                                <td>11</td>
                                                <td>30</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                    <div class="alert alert-light mt-3 small">
                                        <i class="fas fa-info-circle me-1"></i> Lưu ý: Số đo có thể chênh lệch 1-2cm tùy
                                        thuộc vào kiểu dáng giày.
                                    </div>
                                    <% } else { %>
                                        <!-- Clothing Size Table -->
                                        <h6 class="fw-bold mb-3">Bảng Kích Cỡ Quần Áo</h6>
                                        <table class="table table-bordered text-center align-middle">
                                            <thead class="table-dark">
                                                <tr>
                                                    <th>Kích thước</th>
                                                    <th>Chiều cao (cm)</th>
                                                    <th>Cân nặng (kg)</th>
                                                    <th>Vòng ngực (cm)</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td>XS</td>
                                                    <td>150 - 160</td>
                                                    <td>45 - 50</td>
                                                    <td>78 - 82</td>
                                                </tr>
                                                <tr>
                                                    <td>S</td>
                                                    <td>160 - 165</td>
                                                    <td>50 - 55</td>
                                                    <td>82 - 86</td>
                                                </tr>
                                                <tr>
                                                    <td>M</td>
                                                    <td>165 - 170</td>
                                                    <td>55 - 65</td>
                                                    <td>86 - 90</td>

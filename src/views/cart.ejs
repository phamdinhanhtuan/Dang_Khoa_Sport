<%- include('partials/header') %>
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-uppercase mb-0">GIỎ HÀNG CỦA TÔI (<%= cart.items.length %>)</h2>
            <% if (cart.items.length> 0) { %>
                <button id="clearCartBtn"
                    class="btn btn-danger text-white rounded-0 px-4 py-2 fw-bold d-flex align-items-center gap-2">
                    <i class="fas fa-trash"></i> XÓA HẾT
                </button>
                <% } %>
        </div>

        <% if (cart.items.length> 0) { %>
            <div class="row">
                <!-- Cart Items List -->
                <div class="col-lg-8">
                    <div class="d-flex flex-column gap-3">
                        <% cart.items.forEach(item=> { %>
                            <% if (item.product) { %>
                                <div class="card border-0 shadow-sm p-3">
                                    <div class="row g-0">
                                        <div class="col-md-3">
                                            <img src="<%= (item.product.images && item.product.images[0]) || 'https://dummyimage.com/200x200/dee2e6/6c757d.jpg' %>"
                                                class="img-fluid rounded-start bg-light" alt="<%= item.product.name %>"
                                                onerror="this.src='https://dummyimage.com/200x200/dee2e6/6c757d.jpg'">
                                        </div>
                                        <div class="col-md-9">
                                            <div class="card-body py-0 ps-3">
                                                <div class="d-flex justify-content-between mb-2">
                                                    <h5 class="card-title fw-bold mb-0 w-75">
                                                        <%= item.product.name %>
                                                    </h5>
                                                    <h5 class="fw-bold mb-0">
                                                        <%= formatMoney(item.product.price) %>
                                                    </h5>
                                                </div>

                                                <div class="mb-3 text-muted small">
                                                    <p class="mb-1">Màu: <span>
                                                            <%= item.color || 'Mặc định' %>
                                                        </span></p>
                                                    <p class="mb-1">Kích cỡ: <span>
                                                            <%= item.size || 'Tiêu chuẩn' %>
                                                        </span></p>
                                                    <!-- <p class="mb-0">Số kiểu: <span><%= item.product._id.toString().substring(0, 8) %></span></p> -->
                                                </div>

                                                <div class="d-flex justify-content-between align-items-end">
                                                    <div>
                                                        <div class="input-group input-group-sm" style="width: 120px;">
                                                            <button
                                                                class="btn btn-outline-dark rounded-0 px-2 btn-qty-update"
                                                                type="button" data-action="minus"
                                                                data-id="<%= item.product._id %>">
                                                                <i class="fas fa-minus small"></i>
                                                            </button>
                                                            <input type="text"
                                                                class="form-control text-center border-dark border-start-0 border-end-0 fw-bold"
                                                                value="<%= item.quantity %>" readonly
                                                                style="background: transparent;">
                                                            <button
                                                                class="btn btn-outline-dark rounded-0 px-2 btn-qty-update"
                                                                type="button" data-action="plus"
                                                                data-id="<%= item.product._id %>">
                                                                <i class="fas fa-plus small"></i>
                                                            </button>
                                                        </div>
                                                    </div>

                                                    <!-- Actions -->
                                                    <div class="d-flex gap-3">
                                                        <% let isShoe=false; if (item.product.category) { /* DB
                                                            populated object */ if (item.product.category.name) { const
                                                            catName=item.product.category.name.toLowerCase(); const
                                                            catSlug=item.product.category.slug ?
                                                            item.product.category.slug.toLowerCase() : '' ; if
                                                            (catName.includes('giày') || catName.includes('dép') ||
                                                            catSlug.includes('footwear') || catSlug.includes('shoes')) {
                                                            isShoe=true; } } } if (!isShoe && item.product.name) { const
                                                            name=item.product.name.toLowerCase(); if
                                                            (name.includes('giày') || name.includes('dép') ||
                                                            name.includes('shoes') || name.includes('sandal') ||
                                                            name.includes('sneaker')) { isShoe=true; } } %>
                                                            <button class="btn btn-link text-dark p-0 btn-edit-cart"
                                                                data-item-id="<%= item._id %>"
                                                                data-product-id="<%= item.product._id %>"
                                                                data-name="<%= item.product.name %>"
                                                                data-price="<%= formatMoney(item.product.price) %>"
                                                                data-img="<%= (item.product.images && item.product.images[0]) || item.product.image %>"
                                                                data-color="<%= item.color %>"
                                                                data-size="<%= item.size %>"
                                                                data-qty="<%= item.quantity %>"
                                                                data-is-shoe="<%= isShoe %>">
                                                                <i class="fas fa-pen"></i>
                                                            </button>
                                                            <button
                                                                class="btn btn-link text-dark p-0 btn-delete-trigger"
                                                                data-id="<%= item._id || item.product._id %>"
                                                                data-name="<%= item.product.name %>">
                                                                <i class="fas fa-trash-alt"></i>
                                                            </button>
                                                    </div>
                                                </div>

                                                <% if (Math.random()> 0.5) { %>
                                                    <div class="mt-2 text-success small">
                                                        <i class="fas fa-check-circle"></i> CÒN HÀNG
                                                    </div>
                                                    <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                                    <% }) %>
                    </div>
                </div>

                <!-- Order Summary -->
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="card border-0 bg-light p-4">
                        <div class="accordion accordion-flush mb-4 bg-transparent" id="couponAccordion">
                            <div class="accordion-item bg-transparent">
                                <h2 class="accordion-header">
                                    <button
                                        class="accordion-button collapsed bg-transparent px-0 fw-bold text-dark shadow-none"
                                        type="button" data-bs-toggle="collapse" data-bs-target="#flush-collapseOne">
                                        Áp dụng mã khuyến mãi
                                    </button>
                                </h2>
                                <div id="flush-collapseOne" class="accordion-collapse collapse"
                                    data-bs-parent="#couponAccordion">
                                    <div class="accordion-body px-0">
                                        <div class="input-group">
                                            <input type="text" class="form-control" placeholder="Nhập mã">
                                            <button class="btn btn-dark">ÁP DỤNG</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>


                        <!-- Free Shipping Progress -->
                        <% const FREE_SHIP_THRESHOLD=1000000; const cartTotal=cart.totalPrice || 0; const
                            remaining=FREE_SHIP_THRESHOLD - cartTotal; const progressPercent=Math.min((cartTotal /
                            FREE_SHIP_THRESHOLD) * 100, 100); %>
                            <div class="mb-4">
                                <% if (remaining> 0) { %>
                                    <p class="small text-muted mb-1">Mua thêm <span class="fw-bold text-dark">
                                            <%= formatMoney(remaining) %>
                                        </span> để được <span class="fw-bold text-success">Freeship</span>!</p>
                                    <div class="progress" style="height: 6px;">
                                        <div class="progress-bar bg-success" role="progressbar"
                                            style="width: <%= progressPercent %>%;"
                                            aria-valuenow="<%= progressPercent %>" aria-valuemin="0"
                                            aria-valuemax="100"></div>
                                    </div>
                                    <% } else { %>
                                        <div class="alert alert-success py-2 d-flex align-items-center small"
                                            role="alert">
                                            <i class="fas fa-shipping-fast me-2"></i> Bạn đã được Miễn Phí Vận Chuyển!
                                        </div>
                                        <% } %>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Tổng phụ</span>
                                <span class="fw-bold">
                                    <%= formatMoney(cart.totalPrice) %>
                                </span>
                            </div>
                            <div class="d-flex justify-content-between mb-3 border-bottom pb-3">
                                <span>Chi phí vận chuyển</span>
                                <span>0 ₫</span>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <h5 class="fw-bold mb-0">Tổng ước tính</h5>
                                <h5 class="fw-bold mb-0">
                                    <%= formatMoney(cart.totalPrice) %>
                                </h5>
                            </div>
                            <div class="text-muted small mb-4">ĐÃ BAO GỒM 8% thuế VAT</div>

                            <a href="/checkout"
                                class="btn btn-lg w-100 fw-bold text-white d-flex align-items-center justify-content-center gap-2"
                                style="background-color: #a89166; border: none; padding-top: 15px; padding-bottom: 15px;">
                                <i class="fas fa-lock"></i> THANH TOÁN
                            </a>
                    </div>
                </div>
            </div>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="fas fa-shopping-bag fa-4x text-muted mb-3"></i>
                    <h3>Giỏ hàng của bạn đang trống</h3>
                    <p class="text-muted">Có vẻ như bạn chưa thêm sản phẩm nào.</p>
                    <a href="/shop" class="btn btn-dark mt-3 px-4 py-2">TIẾP TỤC MUA SẮM</a>
                </div>
                <% } %>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center p-4 rounded-0">
                <div class="modal-header border-0 justify-content-end p-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0 mt-2">
                    <h4 class="fw-bold mb-3">Xóa sản phẩm?</h4>
                    <p class="mb-4 text-muted" id="deleteModalProductName">Sản phẩm sẽ bị xóa.</p>

                    <button type="button" class="btn w-100 fw-bold text-white mb-2" id="confirmDeleteBtn"
                        style="background-color: #a89166; border: none; padding: 12px;">CÓ, XÓA</button>
                    <button type="button" class="btn btn-link text-dark text-decoration-underline fw-bold small"
                        data-bs-dismiss="modal">KHÔNG, HỦY</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Clear Cart Confirmation Modal -->
    <div class="modal fade" id="clearCartModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-center p-4 rounded-0">
                <div class="modal-header border-0 justify-content-end p-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0 mt-2">
                    <h4 class="fw-bold mb-3">Xóa toàn bộ giỏ?</h4>
                    <p class="mb-4 text-muted">Toàn bộ sản phẩm trong giỏ hàng sẽ bị xóa. Hành động này không thể hoàn
                        tác.</p>

                    <button type="button" class="btn btn-danger w-100 fw-bold text-white mb-2" id="confirmClearCartBtn"
                        style="padding: 12px;">XÓA HẾT</button>
                    <button type="button" class="btn btn-link text-dark text-decoration-underline fw-bold small"
                        data-bs-dismiss="modal">KHÔNG, QUAY LẠI</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Cart Item Modal -->
    <div class="modal fade" id="editCartModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-0">
                <div class="modal-header border-0 pb-0">
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-0">
                    <div class="row">
                        <div class="col-4">
                            <img id="editModalImg" src="" class="img-fluid bg-light" alt="Product">
                        </div>
                        <div class="col-8">
                            <h5 class="fw-bold mb-2" id="editModalName">Product Name</h5>
                            <h5 class="fw-bold mb-3" id="editModalPrice">0 ₫</h5>

                            <input type="hidden" id="editModalProductId">
                            <input type="hidden" id="editModalItemId">

                            <div class="mb-3">
                                <label class="small fw-bold mb-1">MÃU SẮC</label>
                                <div class="d-flex gap-2" id="editModalColors">
                                    <!-- Dynamic -->
                                    <div class="border p-1 selected-color" style="cursor: pointer;">
                                        <img src="https://dummyimage.com/40x40/000/fff" width="40" height="40">
                                    </div>
                                </div>
                            </div>

                            <div class="row g-2 mb-4">
                                <div class="col-6">
                                    <label class="small fw-bold mb-1">KÍCH CỠ</label>
                                    <select class="form-select rounded-0" id="editModalSize">
                                        <option value="39">EUR 39</option>
                                        <option value="40">EUR 40</option>
                                        <option value="40.5">EUR 40.5</option>
                                        <option value="41">EUR 41</option>
                                        <option value="42">EUR 42</option>
                                        <option value="43">EUR 43</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="small fw-bold mb-1">SỐ LƯỢNG</label>
                                    <select class="form-select rounded-0" id="editModalQty">
                                        <option value="1">1</option>
                                        <option value="2">2</option>
                                        <option value="3">3</option>
                                        <option value="4">4</option>
                                        <option value="5">5</option>
                                    </select>
                                </div>
                            </div>

                            <button type="button" class="btn w-100 fw-bold text-white" id="btnUpdateCartItem"
                                style="background-color: #a89166; border: none; padding: 12px;">CẬP NHẬT</button>

                            <div class="text-center mt-2">
                                <a href="#" class="text-dark small text-decoration-underline"
                                    id="btnViewFullDetails">XEM CHI TIẾT ĐẦY ĐỦ</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Clear Cart Logic
            const clearBtn = document.getElementById('clearCartBtn');
            const confirmClearBtn = document.getElementById('confirmClearCartBtn');
            const clearCartModal = new bootstrap.Modal(document.getElementById('clearCartModal'));

            if (clearBtn) {
                clearBtn.addEventListener('click', () => {
                    clearCartModal.show();
                });
            }

            if (confirmClearBtn) {
                confirmClearBtn.addEventListener('click', async () => {
                    const originalText = confirmClearBtn.innerText;
                    confirmClearBtn.disabled = true;
                    confirmClearBtn.innerText = 'ĐANG XÓA...';

                    try {
                        const res = await fetch('/api/cart/clear', { method: 'DELETE' });
                        if (res.ok) window.location.reload();
                        else {
                            alert('Lỗi khi xóa giỏ hàng');
                            confirmClearBtn.disabled = false;
                            confirmClearBtn.innerText = originalText;
                        }
                    } catch (e) {
                        console.error(e);
                        alert('Lỗi kết nối');
                        confirmClearBtn.disabled = false;
                        confirmClearBtn.innerText = originalText;
                    }
                });
            }
        });
    </script>
    <%- include('partials/footer') %>
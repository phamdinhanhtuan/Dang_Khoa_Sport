<!DOCTYPE html>
<html lang="vi">

<head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>
                <%= typeof title !=='undefined' ? title : 'Đăng Khoa Sport' %> | Hệ thống cửa hàng thể thao
        </title>

        <!-- CSS Dependencies -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        <link rel="stylesheet" href="/css/style.css">
        <link rel="stylesheet" href="/css/mega-menu.css">

        <style>
                :root {
                        --primary-blue: #00adef;
                        --dark-blue: #0085b8;
                        --accent-yellow: #ffb900;
                }

                body {
                        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                }

                .header-main {
                        background-color: var(--primary-blue);
                        color: white;
                }

                .nav-bar {
                        background-color: var(--primary-blue);
                        border-top: 1px solid rgba(255, 255, 255, 0.1);
                }

                .mega-trigger {
                        background-color: var(--dark-blue);
                        min-width: 260px;
                }

                .hover-warning:hover {
                        color: var(--accent-yellow) !important;
                }

                .transition-all {
                        transition: all 0.3s ease;
                }

                .dropdown-hover {
                        position: relative;
                }

                .dropdown-hover:hover>.dropdown-menu {
                        display: block;
                        margin-top: 0;
                }

                #megaMenuDropdown:hover>.dropdown-menu {
                        display: block;
                        margin-top: 0;
                }

                .dropdown-hover .dropdown-menu {
                        display: none;
                        border-top: 3px solid var(--accent-yellow) !important;
                        border-radius: 0;
                        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
                        z-index: 1050;
                }

                .mega-menu {
                        z-index: 1100;
                }

                .nav-link.dropdown-toggle::after {
                        display: none !important;
                }
        </style>
</head>

<body class="d-flex flex-column min-vh-100">

        <!-- Promo Bar -->
        <div class="bg-light text-center py-1 border-bottom small fw-bold text-uppercase"
                style="font-size: 10px; letter-spacing: 1px;">
                Miễn phí vận chuyển cho đơn hàng từ 1.200.000đ
        </div>

        <!-- Main Header -->
        <header class="header-main text-white">
                <div class="container py-3">
                        <div class="row align-items-center">
                                <!-- Logo -->
                                <div class="col-lg-3 col-md-4 text-center text-lg-start mb-3 mb-lg-0">
                                        <a href="/"
                                                class="d-inline-flex align-items-center text-white text-decoration-none">
                                                <img src="/img/logo_dk.png" alt="DK Sport" style="height: 45px;">
                                                <span class="fw-bold fs-4 ms-2 text-uppercase">Đăng Khoa Sport</span>
                                        </a>
                                </div>

                                <!-- Search -->
                                <div class="col-lg-5 col-md-8 mb-3 mb-lg-0">
                                        <form action="/products" method="GET">
                                                <div class="input-group">
                                                        <span
                                                                class="input-group-text bg-white border-0 rounded-start-pill ps-3">
                                                                <i class="fas fa-search text-secondary"></i>
                                                        </span>
                                                        <input type="search" name="q"
                                                                class="form-control border-0 rounded-end-pill py-2"
                                                                placeholder="Tìm kiếm sản phẩm..."
                                                                value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
                                                </div>
                                        </form>
                                </div>

                                <!-- Actions -->
                                <div
                                        class="col-lg-4 d-flex align-items-center justify-content-center justify-content-lg-end gap-3">
                                        <!-- Phone -->
                                        <a href="tel:0837633889"
                                                class="d-none d-xl-flex align-items-center px-3 py-1 rounded-pill bg-warning text-dark text-decoration-none">
                                                <i class="fas fa-phone-volume me-2"></i>
                                                <div class="lh-1">
                                                        <small class="d-block fw-bold" style="font-size: 0.6rem;">Tư
                                                                vấn</small>
                                                        <span class="fw-bold">0837633889</span>
                                                </div>
                                        </a>

                                        <!-- User Actions -->
                                        <div class="d-flex gap-2">
                                                <a href="/products" class="btn btn-light rounded-circle shadow-sm"
                                                        style="width: 40px; height: 40px; color: var(--primary-blue);">
                                                        <i class="fas fa-store"></i>
                                                </a>

                                                <!-- Account Dropdown -->
                                                <div class="dropdown">
                                                        <button class="btn btn-light rounded-circle shadow-sm dropdown-toggle no-arrow"
                                                                type="button" data-bs-toggle="dropdown"
                                                                style="width: 40px; height: 40px; color: var(--primary-blue);">
                                                                <i class="fas fa-user"></i>
                                                        </button>
                                                        <ul
                                                                class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                                                <% if (typeof user !=='undefined' && user) { %>
                                                                        <li><span class="dropdown-item-text">Chào, <b>
                                                                                                <%= user.name %>
                                                                                        </b></span></li>
                                                                        <li>
                                                                                <hr class="dropdown-divider">
                                                                        </li>
                                                                        <li><a class="dropdown-item" href="/orders">Đơn
                                                                                        hàng của tôi</a></li>
                                                                        <% if (user.role==='admin' ) { %>
                                                                                <li><a class="dropdown-item text-primary fw-bold"
                                                                                                href="/admin">Quản trị
                                                                                                viên</a></li>
                                                                                <% } %>
                                                                                        <li>
                                                                                                <hr
                                                                                                        class="dropdown-divider">
                                                                                        </li>
                                                                                        <li><a class="dropdown-item text-danger"
                                                                                                        href="/logout">Đăng
                                                                                                        xuất</a></li>
                                                                                        <% } else { %>
                                                                                                <li><a class="dropdown-item"
                                                                                                                href="/login">Đăng
                                                                                                                nhập</a>
                                                                                                </li>
                                                                                                <li><a class="dropdown-item"
                                                                                                                href="/signup">Đăng
                                                                                                                ký</a>
                                                                                                </li>
                                                                                                <% } %>
                                                        </ul>
                                                </div>

                                                <!-- Cart -->
                                                <a href="/cart"
                                                        class="btn btn-light rounded-circle shadow-sm position-relative"
                                                        style="width: 40px; height: 40px; color: var(--primary-blue);">
                                                        <i class="fas fa-shopping-bag"></i>
                                                        <% if (typeof cartCount !=='undefined' && cartCount> 0) { %>
                                                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark border border-light"
                                                                        style="font-size: 0.6rem;">
                                                                        <%= cartCount %>
                                                                </span>
                                                                <% } %>
                                                </a>
                                        </div>
                                </div>
                        </div>
                </div>

                <!-- Navigation Bar -->
                <nav class="nav-bar">
                        <div class="container p-0">
                                <div class="d-flex align-items-center">

                                        <!-- Category Mega Menu -->
                                        <div class="dropdown" id="megaMenuDropdown">
                                                <button class="btn mega-trigger text-white rounded-0 px-4 py-3 fw-bold text-uppercase d-flex align-items-center gap-2"
                                                        type="button" id="megaMenuButton">
                                                        <i class="fas fa-bars"></i> Danh mục sản phẩm
                                                </button>
                                                <div class="dropdown-menu mega-menu p-0 border-0 shadow-lg mt-0 rounded-0"
                                                        style="width: 1000px; max-width: 95vw;">
                                                        <%- include('./mega-menu-content.ejs') %>
                                                </div>
                                                <style>
                                                        /* Helper to prevent hover gap */
                                                        #megaMenuDropdown::after {
                                                                content: "";
                                                                position: absolute;
                                                                top: 100%;
                                                                left: 0;
                                                                width: 100%;
                                                                height: 10px;
                                                                background: transparent;
                                                        }

                                                        .input-group:focus-within {
                                                                box-shadow: 0 0 15px rgba(255, 255, 255, 0.3);
                                                                transform: scale(1.02);
                                                                transition: all 0.2s ease;
                                                        }
                                                </style>
                                        </div>

                                        <!-- Quick Navigation -->
                                        <div class="d-flex align-items-center flex-grow-1 ps-3 overflow-auto">
                                                <% if (typeof headerCategories !=='undefined' &&
                                                        headerCategories.length> 0) { %>
                                                        <% headerCategories.forEach(cat=> { %>
                                                                <% if (cat.group !=='sale' ) { %>
                                                                        <div class="nav-item dropdown dropdown-hover">
                                                                                <a href="/products?cat=<%= cat.slug %>"
                                                                                        class="nav-link text-white text-uppercase py-3 px-3 fw-bold small hover-warning position-relative <%= cat.children && cat.children.length > 0 ? 'dropdown-toggle' : '' %>">
                                                                                        <%= cat.name %>
                                                                                                <% if (cat.showAsHot) {
                                                                                                        %>
                                                                                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark"
                                                                                                                style="font-size: 0.5rem; margin-top: 15px;">HOT</span>
                                                                                                        <% } %>
                                                                                </a>
                                                                                <% if (cat.children &&
                                                                                        cat.children.length> 0) { %>
                                                                                        <ul
                                                                                                class="dropdown-menu border-0 shadow-sm rounded-0">
                                                                                                <%
                                                                                                        cat.children.forEach(child=>
                                                                                                        { %>
                                                                                                        <li><a class="dropdown-item py-2 small"
                                                                                                                        href="/products?cat=<%= child.slug %>">
                                                                                                                        <%= child.name
                                                                                                                                %>
                                                                                                                </a>
                                                                                                        </li>
                                                                                                        <% }) %>
                                                                                        </ul>
                                                                                        <% } %>
                                                                        </div>
                                                                        <% } %>
                                                                                <% }) %>
                                                                                        <% } %>

                                                                                                <!-- Sale Link -->
                                                                                                <% if (typeof
                                                                                                        saleCategory
                                                                                                        !=='undefined'
                                                                                                        && saleCategory)
                                                                                                        { %>
                                                                                                        <a href="/products?cat=<%= saleCategory.slug %>"
                                                                                                                class="nav-link text-warning text-uppercase py-3 px-3 fw-bold small hover-white">
                                                                                                                <i
                                                                                                                        class="fas fa-bolt me-1"></i>
                                                                                                                <%= saleCategory.name
                                                                                                                        %>
                                                                                                        </a>
                                                                                                        <% } else { %>
                                                                                                                <a href="/products?sort=price-asc"
                                                                                                                        class="nav-link text-warning text-uppercase py-3 px-3 fw-bold small hover-white">
                                                                                                                        <i
                                                                                                                                class="fas fa-bolt me-1"></i>
                                                                                                                        XẢ
                                                                                                                        KHO
                                                                                                                        50%
                                                                                                                </a>
                                                                                                                <% } %>
                                        </div>
                                </div>
                        </div>
                </nav>
        </header>

        <main class="flex-grow-1">
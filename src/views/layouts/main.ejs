<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %> | Đăng Khoa Sport
    </title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light sticky-top">
        <div class="container">
            <a class="navbar-brand" href="/">
                <i class="fas fa-running text-danger"></i>
                Đăng Khoa<span class="text-danger">Sport</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link active" href="/">
                            <%= __('nav.home') %>
                        </a></li>
                    <li class="nav-item"><a class="nav-link" href="/shop">
                            <%= __('nav.shop') %>
                        </a></li>
                    <li class="nav-item"><a class="nav-link" href="/#featured">
                            <%= __('nav.new_arrivals') %>
                        </a></li>
                    <li class="nav-item"><a class="nav-link" href="#">
                            <%= __('nav.contact') %>
                        </a></li>
                </ul>

                <ul class="navbar-nav align-items-center">
                    <!-- Language Switcher -->
                    <li class="nav-item me-3">
                        <a href="/lang/vi"
                            class="text-decoration-none <%= locale === 'vi' ? 'fw-bold text-dark' : 'text-muted' %>">VN</a>
                        <span class="text-muted">|</span>
                        <a href="/lang/en"
                            class="text-decoration-none <%= locale === 'en' ? 'fw-bold text-dark' : 'text-muted' %>">EN</a>
                    </li>

                    <li class="nav-item me-2">
                        <a class="nav-link position-relative" href="/cart">
                            <i class="fas fa-shopping-bag fa-lg"></i>
                            <% if (cartCount> 0) { %>
                                <span
                                    class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    <%= cartCount %>
                                </span>
                                <% } %>
                        </a>
                    </li>

                    <% if (user) { %>
                        <li class="nav-item dropdown user-menu">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button"
                                data-bs-toggle="dropdown">
                                <div class="user-avatar">
                                    <i class="fas fa-user"></i>
                                </div>
                                <span>
                                    <%= user.name.split(' ')[0] %></span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg">
                                <% if (user.role === ' admin') { %>
                        <li><a class="dropdown-item" href="/admin"><i class="fas fa-tachometer-alt me-2"></i>
                                <%= __('nav.dashboard') %>
                            </a></li>
                        <% } %>
                            <li><a class="dropdown-item" href="/orders/my"><i class="fas fa-box me-2"></i>
                                    <%= __('nav.my_orders') %>
                                </a>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item text-danger" href="/api/users/logout"><i
                                        class="fas fa-sign-out-alt me-2"></i>
                                    <%= __('nav.logout') %>
                                </a></li>
                </ul>
                </li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="btn btn-outline-dark rounded-pill px-4 ms-2" href="/login">
                            <%= __('nav.login') %>
                        </a>
                    </li>
                    <% } %>
                        </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow-1">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer>
        <div class="container">
            <div class="row gy-5">
                <div class="col-lg-4 col-md-6">
                    <h5 class="mb-3">ĐĂNG KHOA SPORT</h5>
                    <p class="text-white-50">
                        <%= __('footer.premium_desc') %>
                    </p>
                    <div class="social-links mt-4">
                        <a href="#"><i class="fab fa-facebook-f"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-youtube"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5 class="mb-3">
                        <%= __('footer.quick_links') %>
                    </h5>
                    <ul class="list-unstyled">
                        <li><a href="/">
                                <%= __('nav.home') %>
                            </a></li>
                        <li><a href="/shop">
                                <%= __('nav.shop') %>
                            </a></li>
                        <li><a href="/shop?category=men">Men's</a></li>
                        <li><a href="/shop?category=women">Women's</a></li>
                        <li><a href="/shop?category=accessories">Accessories</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5 class="mb-3">
                        <%= __('footer.customer_service') %>
                    </h5>
                    <ul class="list-unstyled">
                        <li><a href="#">Contact Us</a></li>
                        <li><a href="#">Shipping Policy</a></li>
                        <li><a href="#">Returns & Exchanges</a></li>
                        <li><a href="#">FAQs</a></li>
                        <li><a href="#">Size Guide</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h5 class="mb-3">
                        <%= __('footer.contact_info') %>
                    </h5>
                    <ul class="list-unstyled text-white-50">
                        <li class="mb-2"><i class="fas fa-map-marker-alt me-2 text-primary"></i> 123 Sport Street, Ho
                            Chi Minh City</li>
                        <li class="mb-2"><i class="fas fa-phone-alt me-2 text-primary"></i> +84 123 456 789</li>
                        <li class="mb-2"><i class="fas fa-envelope me-2 text-primary"></i> support@dangkhoasport.com
                        </li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 Đăng Khoa Sport. All rights reserved. | <a href="#">Privacy Policy</a> | <a
                        href="#">Terms of Service</a></p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="/js/script.js"></script>
</body>

</html>
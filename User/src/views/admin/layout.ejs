<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin | Đăng Khoa Sport</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { overflow-x: hidden; }
        .sidebar { min-height: 100vh; width: 260px; position: fixed; top: 0; left: 0; z-index: 1000; transition: all 0.3s; }
        .main-wrapper { margin-left: 260px; transition: all 0.3s; }
        .nav-link { color: rgba(255,255,255,0.8); margin-bottom: 5px; }
        .nav-link:hover, .nav-link.active { color: #fff; background-color: rgba(255,255,255,0.1); }
        .card { border: none; box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075); margin-bottom: 20px; }
    </style>
</head>
<body class="bg-light">

<!-- Sidebar -->
<div class="sidebar bg-dark text-white p-3">
    <div class="d-flex align-items-center mb-4 mt-2 px-2">
        <h4 class="m-0 fw-bold">DK Sport Admin</h4>
    </div>
    <hr class="text-secondary">
    <ul class="nav nav-pills flex-column mb-auto">
        <li class="nav-item">
            <a href="/admin" class="nav-link <%= typeof title != 'undefined' && title === 'Dashboard' ? 'active' : '' %>">
                <i class="fas fa-chart-line me-2 w-25"></i> Dashboard
            </a>
        </li>
        <li>
            <a href="/admin/products" class="nav-link <%= typeof title != 'undefined' && title.includes('Product') ? 'active' : '' %>">
                <i class="fas fa-box me-2 w-25"></i> Products
            </a>
        </li>
        <li>
            <a href="/admin/orders" class="nav-link <%= typeof title != 'undefined' && title.includes('Order') ? 'active' : '' %>">
                <i class="fas fa-shopping-bag me-2 w-25"></i> Orders
            </a>
        </li>
        <li>
            <a href="/admin/users" class="nav-link <%= typeof title != 'undefined' && title.includes('User') ? 'active' : '' %>">
                <i class="fas fa-users me-2 w-25"></i> Users
            </a>
        </li>
    </ul>
    <hr class="text-secondary mt-auto">
    <div class="dropdown">
        <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="fas fa-user-circle me-2"></i>
            <strong><%= (typeof user !== 'undefined' && user) ? user.name : 'Admin' %></strong>
        </a>
        <ul class="dropdown-menu dropdown-menu-dark text-small shadow" aria-labelledby="dropdownUser1">
            <li><a class="dropdown-item" href="/">Back to Shop</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/logout">Sign out</a></li> // Adjust logout route if needed
        </ul>
    </div>
</div>

<!-- Main Content Wrapper -->
<div class="main-wrapper">
    <!-- Top Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm mb-4">
        <div class="container-fluid">
            <span class="navbar-text ms-auto text-secondary">
                <small><%= new Date().toLocaleDateString('vi-VN') %></small>
            </span>
        </div>
    </nav>
    
    <!-- Page Content Container -->
    <div class="container-fluid px-4">
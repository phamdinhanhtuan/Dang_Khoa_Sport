<%- include('layout') %>

    <h3 class="mb-4">Orders</h3>

    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Order ID</th>
                            <th>User</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (orders.length> 0) { %>
                            <% orders.forEach(order=> { %>
                                <tr>
                                    <td class="ps-4"><small class="text-muted">#<%= order._id.toString().slice(-6) %>
                                                </small></td>
                                    <td>
                                        <%= order.user ? order.user.name : 'Unknown User' %>
                                    </td>
                                    <td>
                                        <%= new Date(order.createdAt).toLocaleDateString('vi-VN') %>
                                    </td>
                                    <td class="fw-bold">
                                        <%= (typeof formatMoney !=='undefined' ) ? formatMoney(order.totalAmount) :
                                            order.totalAmount %>
                                    </td>
                                    <td>
                                        <% let badgeClass='bg-secondary' ; if(order.status==='completed' )
                                            badgeClass='bg-success' ; if(order.status==='pending' )
                                            badgeClass='bg-warning' ; if(order.status==='cancelled' )
                                            badgeClass='bg-danger' ; %>
                                            <span class="badge <%= badgeClass %>">
                                                <%= order.status %>
                                            </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="/admin/orders/<%= order._id %>" class="btn btn-sm btn-outline-primary">
                                            View Details
                                        </a>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="6" class="text-center py-4">No orders found.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>

    </html>
<!-- Add to Cart Success Modal -->
<!-- Add to Cart Success Modal -->
<div class="modal fade" id="addToCartModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-0">
            <div class="modal-header border-0 bg-success text-white">
                <h6 class="modal-title fw-bold text-uppercase"><i class="fas fa-check-circle me-2"></i> Đã Thêm Vào Giỏ
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                    aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <img id="modalProductImage" src="" alt="Product" class="img-fluid rounded mb-3"
                    style="max-height: 150px; object-fit: contain;">
                <h5 id="modalProductName" class="fw-bold mb-2"></h5>
                <p class="text-muted mb-4">đã được thêm vào giỏ hàng thành công.</p>
                <div class="d-grid gap-2">
                    <a href="/cart" class="btn btn-dark fw-bold text-uppercase py-3">Xem Giỏ Hàng & Thanh Toán</a>
                    <button type="button" class="btn btn-outline-dark text-uppercase py-2" data-bs-dismiss="modal">Tiếp
                        Tục Mua Sắm</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Exit Intent Popup -->
<div class="modal fade" id="exitIntentPopup" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg"
            style="background: url('https://img.freepik.com/free-vector/memphis-abstract-background-white-gray_53876-113941.jpg'); background-size: cover;">
            <div class="modal-body p-5 text-center position-relative">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal"
                    aria-label="Close"></button>
                <div class="mb-3 text-warning">
                    <i class="fas fa-gift fa-3x"></i>
                </div>
                <h2 class="fw-bold text-uppercase mb-2">Chờ Đã!</h2>
                <p class="lead mb-4">Đừng bỏ lỡ ưu đãi dành riêng cho bạn.</p>
                <div class="bg-white p-3 rounded shadow-sm border border-2 border-warning mb-4 mx-auto"
                    style="max-width: 300px;">
                    <p class="small text-muted mb-1 text-uppercase fw-bold">Mã Giảm Giá 10%</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fs-4 fw-bold text-dark letter-spacing-2">SAVE10</span>
                        <button class="btn btn-outline-dark btn-sm" onclick="copyCode(this, 'SAVE10')">Copy</button>
                    </div>
                </div>
                <p class="small text-muted mb-4">Áp dụng cho đơn hàng đầu tiên. Hết hạn trong 24h.</p>
                <button type="button" class="btn btn-dark w-100 py-3 fw-bold text-uppercase"
                    data-bs-dismiss="modal">Tiếp tục mua sắm</button>
            </div>
        </div>
    </div>
</div>

<!-- Chatbot Widget -->
<div id="chatbot-container" style="position: fixed; bottom: 30px; right: 30px; z-index: 9999;">
    <!-- Chat Button -->
    <button id="chatbot-toggle"
        class="btn btn-dark rounded-circle shadow-lg d-flex align-items-center justify-content-center"
        style="width: 60px; height: 60px;">
        <i class="fas fa-comment-dots fa-lg text-white"></i>
    </button>

    <!-- Chat Window -->
    <div id="chatbot-window" class="card shadow-lg d-none"
        style="position: absolute; bottom: 80px; right: 0; width: 350px; height: 500px; border-radius: 15px; border: none; overflow: hidden;">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center py-3">
            <h6 class="mb-0 fw-bold"><i class="fas fa-robot me-2"></i> Trợ Lý Ảo</h6>
            <button id="chatbot-close" class="btn btn-sm text-white"><i class="fas fa-times"></i></button>
        </div>
        <div class="card-body bg-light p-3" id="chatbot-messages" style="overflow-y: auto; height: 380px;">
            <div class="d-flex mb-3">
                <div class="bg-white p-2 rounded shadow-sm" style="max-width: 80%;">
                    Xin chào! Tôi có thể giúp gì cho bạn hôm nay?
                </div>
            </div>
            <!-- Suggestion Chips -->
            <div class="d-flex flex-wrap gap-2 mb-3">
                <button class="btn btn-sm btn-outline-dark rounded-pill chatbot-chip">Chính sách đổi trả</button>
                <button class="btn btn-sm btn-outline-dark rounded-pill chatbot-chip">Phí vận chuyển</button>
                <button class="btn btn-sm btn-outline-dark rounded-pill chatbot-chip">Theo dõi đơn hàng</button>
            </div>
        </div>
        <div class="card-footer bg-white border-top p-2">
            <form id="chatbot-form" class="d-flex gap-2">
                <input type="text" class="form-control border-0 bg-light" placeholder="Nhập tin nhắn..." required>
                <button type="submit" class="btn btn-dark rounded-circle"><i class="fas fa-paper-plane"></i></button>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>

</html>
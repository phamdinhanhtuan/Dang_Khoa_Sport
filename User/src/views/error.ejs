<%- include('partials/header') %>
    <div class="container py-5 text-center">
        <div class="alert alert-danger shadow-sm">
            <h1 class="display-4 fw-bold"><i class="fas fa-exclamation-triangle me-3"></i>Oops!</h1>
            <h2 class="mb-4">
                <%= title || 'Something went wrong!' %>
            </h2>
            <p class="lead">
                <%= message %>
            </p>
            <% if (process.env.NODE_ENV==='development' && error.stack) { %>
                <div class="text-start mt-4 bg-light p-3 rounded overflow-auto" style="max-height: 300px;">
                    <code><pre><%= error.stack %></pre></code>
                </div>
                <% } %>
                    <a href="/" class="btn btn-primary btn-lg mt-4 fw-bold">Go Home</a>
        </div>
    </div>
    <%- include('partials/footer') %>
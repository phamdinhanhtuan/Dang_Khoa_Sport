<%- include('partials/header') %>
    <div class="container py-5">
        <h2 class="fw-bold text-uppercase mb-4 text-center">Danh Sách Yêu Thích</h2>

        <% if (wishlist && wishlist.length> 0) { %>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
                <% wishlist.forEach(product=> { %>
                    <div class="col">
                        <div class="product-card h-100 position-relative">
                            <button
                                class="btn btn-sm btn-light position-absolute top-0 end-0 m-2 rounded-circle shadow-sm btn-remove-wishlist"
                                style="z-index: 10;" data-id="<%= product._id %>" title="Xóa khỏi yêu thích">
                                <i class="fas fa-times"></i>
                            </button>
                            <div class="product-img-wrapper"
                                onclick="window.location.href='/product/<%= product._id %>'" style="cursor: pointer;">
                                <img src="<%= (product.images && product.images[0]) || (product.image || '/img/default-product.png') %>"
                                    alt="<%= product.name %>" onerror="this.src='/img/default-product.png'">
                            </div>
                            <div class="product-info p-3">
                                <div class="product-brand">
                                    <%= product.brand %>
                                </div>
                                <h3 class="product-name"><a href="/product/<%= product._id %>"
                                        class="text-dark text-decoration-none">
                                        <%= product.name %>
                                    </a></h3>
                                <div class="product-price">
                                    <%= formatMoney(product.price) %>
                                </div>
                                <button class="btn-add-cart mt-2 w-100" data-id="<%= product._id %>">Thêm vào
                                    giỏ</button>
                            </div>
                        </div>
                    </div>
                    <% }) %>
            </div>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="far fa-heart fa-4x text-muted mb-3"></i>
                    <h3>Danh sách yêu thích trống</h3>
                    <p class="text-muted">Hãy thêm những sản phẩm bạn yêu thích vào đây.</p>
                    <a href="/shop" class="btn btn-dark mt-3 px-4 py-2">KHÁM PHÁ NGAY</a>
                </div>
                <% } %>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Handle Remove from Wishlist
            document.querySelectorAll('.btn-remove-wishlist').forEach(btn => {
                btn.addEventListener('click', async (e) => {
                    e.stopPropagation();
                    if (!confirm('Xóa sản phẩm này khỏi danh sách yêu thích?')) return;

                    const productId = btn.dataset.id;
                    try {
                        const res = await fetch('/api/users/wishlist', {
                            method: 'POST', // Only POST route was created, handles toggle
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ productId })
                        });
                        const data = await res.json();

                        if (data.status === 'success') {
                            window.location.reload();
                        } else {
                            alert(data.message || 'Lỗi');
                        }
                    } catch (err) {
                        console.error(err);
                        alert('Lỗi kết nối');
                    }
                });
            });
        });
    </script>
    <%- include('partials/footer') %>